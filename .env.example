# ============================================================================
# clab-platform environment variables
# Copy to .env and fill in your API keys:  cp .env.example .env
# ============================================================================

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# --- Database ---
DATABASE_URL=postgres://clab:clab_secret@localhost:5432/clab

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- JWT ---
JWT_SECRET=change-me-in-production

# --- Logging ---
LOG_LEVEL=debug
NODE_ENV=development

# --- Platform State Sync (optional) ---
# Set to sync local cmux task state to K8s platform dashboard
# CLAB_API_URL=https://ai.clab.one
# CLAB_API_TOKEN=              # optional: Bearer token for API auth

# --- OpenTelemetry (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
