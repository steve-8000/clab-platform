# clab-platform environment
# Copy to .env: cp .env.example .env

# --- API Keys (optional — CLI sessions are preferred) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Database ---
DATABASE_URL=postgres://clab:clab_secret@localhost:5432/clab

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- JWT ---
JWT_SECRET=change-me-in-production

# --- Logging ---
LOG_LEVEL=debug
NODE_ENV=development

# --- Platform URLs ---
# Default: hosted platform at ai.clab.one (no config needed)
# Override for local dev (port-forward mode):
# CLAB_CONTROL_URL=http://localhost:8000
# CLAB_KNOWLEDGE_URL=http://localhost:4007

# --- OpenTelemetry (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
