{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clab.dev/schemas/event.schema.json",
  "title": "Event",
  "description": "Event envelope for the clab event bus (NATS). Every domain event conforms to this envelope.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier for deduplication."
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z]+\\.[a-z_]+$",
      "description": "Dot-namespaced event type, e.g. 'mission.created', 'task.completed'.",
      "examples": [
        "mission.created",
        "mission.completed",
        "task.queued",
        "task.started",
        "task.completed",
        "task.failed",
        "decision.recorded",
        "approval.requested",
        "approval.granted",
        "approval.rejected"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "default": "1.0",
      "description": "Schema version of this event type."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the event was produced."
    },
    "actor": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "system"],
          "description": "Category of the actor."
        },
        "id": {
          "type": "string",
          "description": "Actor identifier (user ID, agent session ID, or 'system')."
        },
        "role": {
          "type": "string",
          "description": "Optional role label, e.g. 'orchestrator', 'codex', 'reviewer'."
        }
      },
      "required": ["type", "id"],
      "additionalProperties": false,
      "description": "Who or what produced this event."
    },
    "source": {
      "type": "string",
      "description": "Service or component that emitted the event.",
      "examples": ["orchestrator", "runtime-manager", "api-gateway", "worker-codex"]
    },
    "subject": {
      "type": "object",
      "properties": {
        "missionId": { "type": "string", "format": "uuid" },
        "taskId": { "type": "string", "format": "uuid" },
        "decisionId": { "type": "string", "format": "uuid" },
        "approvalId": { "type": "string", "format": "uuid" }
      },
      "additionalProperties": false,
      "description": "References to domain entities this event relates to."
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "description": "Event-type-specific data."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "traceId": { "type": "string", "description": "OpenTelemetry trace ID." },
        "spanId": { "type": "string", "description": "OpenTelemetry span ID." },
        "correlationId": { "type": "string", "description": "Correlation ID for request chains." },
        "causationId": { "type": "string", "format": "uuid", "description": "ID of the event that caused this one." }
      },
      "additionalProperties": true,
      "description": "Observability and correlation metadata."
    }
  },
  "required": ["id", "type", "timestamp", "actor", "source", "payload"],
  "additionalProperties": false
}
