{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clab.dev/schemas/approval.schema.json",
  "title": "Approval",
  "description": "A human-in-the-loop approval gate that must be resolved before work proceeds.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique approval identifier."
    },
    "missionId": {
      "type": "string",
      "format": "uuid",
      "description": "Mission this approval belongs to."
    },
    "taskId": {
      "type": "string",
      "format": "uuid",
      "description": "Task that is blocked pending this approval."
    },
    "gate_type": {
      "type": "string",
      "enum": [
        "pre_execution",
        "post_execution",
        "destructive_action",
        "cost_threshold",
        "security_review",
        "deployment",
        "custom"
      ],
      "description": "Category of approval gate."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected", "expired", "auto_approved"],
      "default": "pending",
      "description": "Current approval status."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Short description of what needs approval."
    },
    "description": {
      "type": "string",
      "description": "Detailed context for the approver."
    },
    "requestedBy": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["user", "agent", "system"] },
        "id": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["type", "id"],
      "additionalProperties": false,
      "description": "Actor that requested this approval."
    },
    "resolvedBy": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["user", "agent", "system"] },
        "id": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["type", "id"],
      "additionalProperties": false,
      "description": "Actor that resolved (approved/rejected) this gate."
    },
    "resolution": {
      "type": "object",
      "properties": {
        "comment": { "type": "string", "description": "Approver's comment or reason." },
        "conditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Conditions attached to the approval."
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "uri": { "type": "string" },
          "type": { "type": "string", "enum": ["diff", "log", "screenshot", "report", "other"] }
        },
        "required": ["label"],
        "additionalProperties": false
      },
      "description": "Supporting evidence presented to the approver."
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "Auto-expire deadline; if unresolved by this time, status becomes 'expired'."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "resolvedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "missionId", "gate_type", "status", "title", "requestedBy", "createdAt", "updatedAt"],
  "additionalProperties": false
}
