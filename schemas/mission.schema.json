{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clab.dev/schemas/mission.schema.json",
  "title": "Mission",
  "description": "A high-level mission that decomposes into tasks for multi-agent orchestration.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique mission identifier."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Human-readable mission title."
    },
    "description": {
      "type": "string",
      "description": "Detailed description of what the mission should accomplish."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "planning", "active", "paused", "completed", "failed", "cancelled"],
      "default": "draft",
      "description": "Current lifecycle status of the mission."
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "default": "medium",
      "description": "Mission priority level."
    },
    "owner": {
      "type": "string",
      "description": "User or system principal that owns this mission."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Freeform tags for categorisation and filtering."
    },
    "context": {
      "type": "object",
      "description": "Arbitrary structured context passed to agents.",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "properties": {
        "maxConcurrentTasks": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Maximum number of tasks that can run in parallel."
        },
        "timeoutMinutes": {
          "type": "integer",
          "minimum": 1,
          "description": "Global timeout for the entire mission."
        },
        "budgetCentsUsd": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum cost budget in USD cents."
        },
        "requireApproval": {
          "type": "boolean",
          "default": false,
          "description": "Whether human approval gates are required before execution."
        }
      },
      "additionalProperties": false
    },
    "taskIds": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "description": "Ordered list of task IDs belonging to this mission."
    },
    "decisionIds": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "description": "Decision records linked to this mission."
    },
    "progress": {
      "type": "object",
      "properties": {
        "totalTasks": { "type": "integer", "minimum": 0 },
        "completedTasks": { "type": "integer", "minimum": 0 },
        "failedTasks": { "type": "integer", "minimum": 0 },
        "percentage": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false,
      "description": "Computed progress summary."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 creation timestamp."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 last-update timestamp."
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 completion timestamp; null while in-progress."
    }
  },
  "required": ["id", "title", "status", "owner", "createdAt", "updatedAt"],
  "additionalProperties": false
}
