{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clab.dev/schemas/task-result.schema.json",
  "title": "TaskResult",
  "description": "Standardised contract for the output of any agent task execution.",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failure", "error"],
      "description": "Outcome status of the task execution."
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary of what was accomplished."
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Relative file path." },
          "action": {
            "type": "string",
            "enum": ["created", "modified", "deleted", "renamed"],
            "description": "Type of change."
          },
          "diff": { "type": "string", "description": "Optional unified diff snippet." }
        },
        "required": ["path", "action"],
        "additionalProperties": false
      },
      "description": "List of files created, modified, or deleted."
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Artifact name or label." },
          "type": {
            "type": "string",
            "enum": ["file", "url", "log", "screenshot", "report", "other"],
            "description": "Artifact category."
          },
          "uri": { "type": "string", "description": "Location of the artifact (path or URL)." },
          "sizeBytes": { "type": "integer", "minimum": 0 }
        },
        "required": ["name", "type", "uri"],
        "additionalProperties": false
      },
      "description": "Produced artifacts such as logs, screenshots, or reports."
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "description": { "type": "string" },
          "mitigation": { "type": "string" }
        },
        "required": ["severity", "description"],
        "additionalProperties": false
      },
      "description": "Identified risks or concerns requiring attention."
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "suggestedRole": {
            "type": "string",
            "enum": ["codex", "claude", "browser", "reviewer", "planner", "custom"]
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        },
        "required": ["title"],
        "additionalProperties": false
      },
      "description": "Suggested follow-up tasks the orchestrator should consider."
    },
    "metrics": {
      "type": "object",
      "properties": {
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Wall-clock execution time in milliseconds."
        },
        "tokensIn": {
          "type": "integer",
          "minimum": 0,
          "description": "Input tokens consumed."
        },
        "tokensOut": {
          "type": "integer",
          "minimum": 0,
          "description": "Output tokens generated."
        },
        "costCentsUsd": {
          "type": "number",
          "minimum": 0,
          "description": "Estimated cost in USD cents."
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retry attempts."
        },
        "custom": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Custom numeric metrics."
        }
      },
      "additionalProperties": false,
      "description": "Execution metrics for observability and cost tracking."
    }
  },
  "required": ["status", "summary"],
  "additionalProperties": false
}
